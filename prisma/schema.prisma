generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enum untuk role/peran pengguna
enum Peran {
  ADMIN
  SUPPLIER
  PEMBELI
}

// Tabel Akun (User)
model akun {
  uniqueID        Int      @id @default(autoincrement())
  nama            String
  email           String   @unique
  password        String
  peran           Peran
  dibuat_pada     DateTime @default(now())
  diperbarui_pada DateTime @updatedAt
}
